KRAKEN_API_KEY=
KRAKEN_API_SECRET=
KRAKEN_ENV=live
EXECUTION_MODE=live

TRADER_SYMBOLS=ETH/USD,BTC/USD,SOL/USD,ADA/USD
USE_ACTIVE_UNIVERSE=true
DATA_SOURCE=live
TRADER_DECISION_ENGINE=llm
RUN_ONCE_ON_STATIC=false
USE_MOCK_STREAM=false

PHI3_BASE_URL=http://127.0.0.1:8084
PHI3_MODEL=phi3
ADVISORY_MODEL_PROVIDER=local_nemo
NEMOTRON_BATCH_SKIP_PHI3=false
ADVISORY_LOCAL_BASE_URL=http://127.0.0.1:11434
LOCAL_STRATEGIST_MODEL=mirage335/NVIDIA-Nemotron-Nano-9B-v2-virtuoso:latest
ADVISORY_LOCAL_MODEL=mirage335/NVIDIA-Nemotron-Nano-9B-v2-virtuoso:latest
NEMOTRON_BASE_URL=http://127.0.0.1:11434
NEMOTRON_MODEL=mirage335/NVIDIA-Nemotron-Nano-9B-v2-virtuoso:latest
NEMOTRON_PROVIDER=local
NEMOTRON_STRATEGIST_PROVIDER=local
LOCAL_LLM_BACKEND=ollama
LOCAL_LLM_LOAD_KEY=mirage335/NVIDIA-Nemotron-Nano-9B-v2-virtuoso:latest
# Cloud Nemotron compatibility aliases. Either set these or the NVIDIA_* names below.
NEMOTRON_CLOUD_API_KEY=
NEMOTRON_CLOUD_URL=https://integrate.api.nvidia.com/v1
NEMOTRON_CLOUD_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5
NVIDIA_API_KEY=
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5
NVIDIA_OPTIMIZER_ENABLED=true
NVIDIA_OPTIMIZER_INTERVAL_MIN=30
NVIDIA_OPTIMIZER_APPLY=false
NVIDIA_OPTIMIZER_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5
KRAKEN_TRADE_HISTORY_ZIP=
NEMOTRON_TOP_CANDIDATE_COUNT=20
NEMOTRON_BATCH_MODE=true
NEMOTRON_BATCH_TOP_N=4
NEMOTRON_LOCAL_TIMEOUT_SEC=120
NEMOTRON_BATCH_MAX_TOKENS=1800
NEMOTRON_ALLOW_BUY_LOW_OUTSIDE_TOP=true
NEMOTRON_ALLOW_BUY_MEDIUM_OUTSIDE_TOP=true
NEMOTRON_ALLOW_WATCH_LOW_LANE_CONFLICT=true
NEMOTRON_GATE_MIN_ENTRY_SCORE=46
ADVISORY_MIN_ENTRY_SCORE=56
MEME_NEMOTRON_GATE_MIN_ENTRY_SCORE=38
MEME_NEMOTRON_WATCH_MIN_ENTRY_SCORE=34

MCP_HOST=0.0.0.0
MCP_PORT=8765
MCP_PUBLIC_ENABLED=false
MCP_PUBLIC_HOSTNAME=
MCP_TUNNEL_NAME=
CLOUDFLARED_EXE=cloudflared

KRAKEN_WS_URL=wss://ws.kraken.com/v2
LIVE_SNAPSHOT_DIR=logs/live

MEME_SYMBOLS=DOGE/USD,SHIB/USD,PEPE/USD,WIF/USD,BONK/USD,FARTCOIN/USD,TRUMP/USD,PENGU/USD,PUMP/USD,USELESS/USD,SPX/USD
TRADER_BASE_MOMO_THRESHOLD=0.0
TRADER_ATR_VOLATILITY_SCALE=0.03
TRADER_RSI_OVERBOUGHT=78.0
TRADER_RSI_OVERSOLD=28.0
MEME_BASE_MOMO_THRESHOLD=-0.003
MEME_ATR_VOLATILITY_SCALE=0.015
MEME_RSI_OVERBOUGHT=88.0
MEME_RSI_OVERSOLD=18.0
TRADER_BB_BREAKOUT_ZSCORE=1.0
TRADER_SMOOTHING_BARS=1
TRADER_COOLDOWN_BARS=0
TRADER_PROPOSED_WEIGHT=0.1
MEME_PROPOSED_WEIGHT=0.04
MEME_TREND_CONFLICT_SCALE=0.5
# Exit multipliers — stop and take profit distances from entry (in ATR units)
# L3 / fallback
EXIT_ATR_STOP_MULT=2.5
EXIT_ATR_TAKE_PROFIT_MULT=5.0
# Break-even only fires late — trail handles profit locking earlier
# L3 / fallback: BE at 3R so trail at 2R runs first
EXIT_BREAK_EVEN_R=3.0
EXIT_TRAIL_ARM_R=2.0
EXIT_TRAIL_ATR_MULT=1.5
# L1 (blue chip — let it run, BE only as last resort at 5R)
L1_EXIT_ATR_STOP_MULT=2.0
L1_EXIT_ATR_TAKE_PROFIT_MULT=8.0
L1_BREAK_EVEN_R=5.0
L1_TRAIL_ARM_R=3.0
L1_TRAIL_ATR_MULT=2.0
# L2 (rotation — BE at 3.5R, trail leads at 2.5R)
L2_EXIT_ATR_STOP_MULT=1.8
L2_EXIT_ATR_TAKE_PROFIT_MULT=6.0
L2_BREAK_EVEN_R=3.5
L2_TRAIL_ARM_R=2.5
L2_TRAIL_ATR_MULT=1.5
# L4 (meme — faster moves, BE at 2R, trail at 1.5R)
MEME_EXIT_ATR_STOP_MULT=2.8
MEME_EXIT_ATR_TAKE_PROFIT_MULT=7.0

MEME_BREAK_EVEN_R=1.0
MEME_TRAIL_ARM_R=1.5
MEME_TRAIL_ATR_MULT=1.0
ORDER_PREFERENCE=auto
ORDER_LIMIT_OFFSET_BPS=5.0
MEME_ORDER_LIMIT_OFFSET_BPS=8.0
EXEC_MAX_SPREAD_PCT=1.5
MEME_EXEC_MAX_SPREAD_PCT=2.5
EXEC_MIN_NOTIONAL_USD=10.0
MEME_EXEC_MIN_NOTIONAL_USD=10.0
EXEC_MAKER_FEE_PCT=0.23
EXEC_TAKER_FEE_PCT=0.40
EXEC_SLIPPAGE_ATR_MULT=0.10
MEME_EXEC_SLIPPAGE_ATR_MULT=0.14
EXEC_RISK_PER_TRADE_PCT=20.0
L1_EXEC_RISK_PER_TRADE_PCT=50.0
L2_EXEC_RISK_PER_TRADE_PCT=50.0
MEME_EXEC_RISK_PER_TRADE_PCT=15.0

RISK_MAX_POSITION_NOTIONAL=2000.0
RISK_MAX_LEVERAGE=2.0

PORTFOLIO_MAX_WEIGHT_PER_SYMBOL=0.2
PORTFOLIO_MAX_TOTAL_GROSS_EXPOSURE=0.80
PORTFOLIO_MAX_OPEN_POSITIONS=4
PORTFOLIO_CORR_THRESHOLD=0.65
PORTFOLIO_CORR_SCALE_DOWN=0.5
PORTFOLIO_MAX_HIGH_CORR_SAME_DIRECTION=1
MEME_MAX_OPEN_POSITIONS=2

WARMUP_MIN_BARS_1M=25
WARMUP_MIN_BARS_5M=6
WARMUP_MIN_BARS_15M=4
WARMUP_MIN_BARS_1H=8
WARMUP_MIN_BARS_7D=6
WARMUP_MIN_BARS_30D=4
WARMUP_HARD_TIMEFRAMES=1m
INTRABAR_PRICE_THRESHOLD=0.0015
LOOP_ALIVE_LOG=true
ACCOUNT_SYNC_INTERVAL_SEC=30

# Dust threshold — positions below this USD value are excluded from equity and not traded.
# Must be >= EXEC_MIN_NOTIONAL_USD or the sweep will skip them. Default: 5.0
ACCOUNT_DUST_USD_THRESHOLD=5.0

PAIR_POOL_FILE=pair_pool_usd.txt
ACTIVE_MIN=30
ACTIVE_MAX=85
ROTATION_SHORTLIST_SIZE=85
# Lane percentage allocation — each lane gets this % of ROTATION_SHORTLIST_SIZE slots
# Must sum to 100. Override fixed counts with LANE_SHORTLIST_LIMITS=L1:3,L2:4,L3:3,L4:2
LANE_SHORTLIST_PCT=L1:25,L2:30,L3:30,L4:15
MIN_QUOTE_VOLUME_USD=200000
MAX_SPREAD_BPS=25
MIN_AGE_DAYS=14
MIN_PRICE=0.01
MAX_ADDS_PER_REBALANCE=10
MAX_REMOVES_PER_REBALANCE=10
PAIR_COOLDOWN_MINUTES=180
START_REPLAY_ON_START=false
REPLAY_SYMBOLS=BTC/USD DOGE/USD AVAX/USD
REPLAY_START_CASH=1000
REPLAY_WARMUP_BARS=60
REPLAY_MAX_STEPS=300
REPLAY_SUMMARY_PATH=logs/replay_summary.json
REPLAY_TRACE_PATH=logs/replay_traces.jsonl

# Kelly Criterion position sizer — set false to lock manual risk settings in place
KELLY_ENABLED=false
KELLY_MIN_PCT=10.0
KELLY_MAX_PCT=30.0

START_OPERATOR_UI_ON_START=true
OPERATOR_UI_HOST=127.0.0.1
OPERATOR_UI_PORT=8780
